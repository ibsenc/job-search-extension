{
  "manifest_version": 3,
  "name": "Job Search Tracker",
  "version": "1.0.2",
  "description": "Tracks job applications automatically and monitors email responses.",

  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "https://mail.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Search Tracker",
    "default_icon": {
      "16": "images/job-search-extension-16.png",
      "32": "images/job-search-extension-32.png",
      "48": "images/job-search-extension-48.png",
      "128": "images/job-search-extension-128.png"
    }
  },

  "icons": {
    "16": "images/job-search-extension-16.png",
    "32": "images/job-search-extension-32.png",
    "48": "images/job-search-extension-48.png",
    "128": "images/job-search-extension-128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://mail.yahoo.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*"
      ],
      "js": ["email-content.js"],
      "run_at": "document_idle"
    }
  ]
}
